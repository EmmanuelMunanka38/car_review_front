# Example environment variables for local development
# Set these in a local .env file (do NOT commit your real key)

# Full listing endpoint or base URL for the car API you want to use.
# Example: https://api.carapi.dev/v1/vehicles
VITE_CARAPI_URL=

# Your carAPI.dev API key
VITE_CARAPI_KEY=

# Existing backend URL (optional)
VITE_API_URL=http://localhost:4000/